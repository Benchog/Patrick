# Copy to `.env.local` in the project root (same folder as package.json).
# Remove the # before each line you need, then fill in real values.
# Restart `npm run dev` after saving.

# Optional: point the AI assistant at another chat URL during dev
# VITE_CHAT_API_URL=http://localhost:3000/api/chat

# Supabase (Pricing section) — Dashboard → Project Settings → API
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Service request email (Vercel serverless API /api/service-request)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# SERVICE_REQUEST_TO_EMAIL=pat.benchog@gmail.com
# SERVICE_REQUEST_FROM_EMAIL=Portfolio Requests <onboarding@resend.dev>

# Production (Vercel): add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in
# Project → Settings → Environment Variables, then Redeploy.
# .env.local is NOT uploaded to Vercel.
